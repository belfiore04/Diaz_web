---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  currentProject?: string;
  bgImage?: string;
  highlightColor?: string;
  bgOverlay?: number; // 0~1, 背景图上的黑色遮罩透明度
  navColor?: string;
  logoColor?: string; // 不传则跟 navColor 一致
}

const {
  title = '李多迪 — Diaz Lee',
  description = '李多迪的个人作品集',
  currentProject,
  bgImage = '/SC.png',
  highlightColor = '#0051FF',
  bgOverlay = 0,
  navColor = '#fff',
  logoColor,
} = Astro.props;

const resolvedLogoColor = logoColor ?? navColor;

const projects = [
  { slug: 'similar-case-search', title: '类案检索\n与对比报告生成系统' },
  { slug: 'meishuguan',          title: '美「书」馆' },
  { slug: 'forget-me-not',       title: 'Forget Me Not' },
  { slug: 'lemon-tea-ip',        title: '柠檬茶IP设计' },
];
---

<!doctype html>
<html lang="zh-Hans">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Kameron:wght@400;700&family=Assistant:wght@400;700;800&family=Noto+Serif+SC:wght@400;700;900&display=swap"
      rel="stylesheet"
    />
    <meta name="description" content={description} />
    <title>{title}</title>
    <style is:global define:vars={{ bgImage: `url('${bgImage}')`, highlightColor, bgOverlayAlpha: String(bgOverlay), navColor, logoColor: resolvedLogoColor }}>
      :root {
        --nav-left: 1.5vw;
        --nav-width: 17vw;
        --main-left: 19.5vw;
        --nav-font: clamp(16px, 1.5625vw, 32px);
      }
      html, body {
        margin: 0;
        padding: 0;
        color: #fff;
        font-family: 'Kameron', 'Noto Serif SC', 'Songti SC', serif;
      }
      body {
        background-image: var(--bgImage);
        background-repeat: no-repeat;
        background-position: top left;
        background-attachment: fixed;
        background-size: 100% 100%; /* 横向严格 1:1 锁定 viewport,确保 nav 落在背景蓝色块上 */
        background-color: #0A0A0A;
        min-height: 100vh;
      }
      .bg-overlay {
        position: fixed;
        inset: 0;
        background: rgba(0, 0, 0, var(--bgOverlayAlpha));
        pointer-events: none;
        z-index: 0;
      }
      .site-nav {
        position: fixed;
        left: var(--nav-left);
        top: 0;
        width: var(--nav-width);
        min-width: 180px;
        height: 100vh;
        padding-top: 13vh;
        padding-bottom: 5vh;
        display: flex;
        flex-direction: column;
        font-family: 'Kameron', 'Noto Serif SC', serif;
        font-weight: 700;
        font-size: var(--nav-font);
        color: var(--navColor);
        z-index: 50;
        line-height: 1.18;
        background: transparent;
      }
      .site-nav a {
        color: inherit;
        text-decoration: none;
        display: inline-block;
        transform-origin: left center;
        transition: color .15s ease, transform .15s ease;
      }
      .site-nav a:hover {
        color: var(--highlightColor);
        transform: scale(1.04);
      }
      .site-nav .logo { color: var(--logoColor); }
      @media (prefers-reduced-motion: reduce) {
        .site-nav a:hover { transform: none; }
      }
      .nav-name-zh {
        font-family: 'Assistant', 'Noto Serif SC', serif;
        white-space: pre;
        margin-top: 0.4em;
      }
      .nav-section {
        margin-top: clamp(40px, 12vh, 180px);
        margin-bottom: clamp(16px, 5vh, 75px);
      }
      .nav-projects {
        display: flex;
        flex-direction: column;
        gap: clamp(10px, 1.6vh, 24px);
        padding-left: clamp(10px, 1.4vw, 36px);
      }
      .nav-project { white-space: pre-line; }
      .nav-project[data-current="true"],
      .nav-project[data-current="true"]:hover { color: var(--highlightColor); }
      .nav-corner { margin-top: clamp(30px, 9vh, 130px); }
      .site-main {
        margin-left: var(--main-left);
        min-height: 100vh;
        position: relative;
        z-index: 1;
      }

      /* Lightbox 全屏看大图 */
      .lightbox-overlay {
        display: none;
        position: fixed;
        inset: 0;
        z-index: 9999;
        background: rgba(0, 0, 0, 0.92);
        align-items: center;
        justify-content: center;
        cursor: zoom-out;
      }
      .lightbox-overlay.is-open { display: flex; }
      .lightbox-overlay img {
        max-width: 92vw;
        max-height: 92vh;
        object-fit: contain;
        cursor: zoom-out;
        border-radius: 12px;
      }
    </style>
  </head>
  <body>
    {bgOverlay > 0 && <div class="bg-overlay"></div>}

    <nav class="site-nav">
      <a href="/" class="logo">
        <div>Diaz Lee</div>
        <div class="nav-name-zh">李      多迪</div>
      </a>

      <div class="nav-section">项目 · Projects</div>

      <div class="nav-projects">
        {projects.map((p) => (
          <a
            href={`/projects/${p.slug}`}
            class="nav-project"
            data-current={currentProject === p.slug ? 'true' : 'false'}
          >{p.title}</a>
        ))}
      </div>

      <a href="/corner" class="nav-corner">角落 · Corner</a>
    </nav>

    <main class="site-main">
      <slot />
    </main>

    <!-- Lightbox -->
    <div id="lightbox" class="lightbox-overlay">
      <img id="lightbox-img" alt="" />
    </div>

    <script is:inline>
      document.addEventListener('DOMContentLoaded', () => {
        const lightbox = document.getElementById('lightbox');
        const lightboxImg = document.getElementById('lightbox-img');
        document.addEventListener('click', (e) => {
          const t = e.target;
          if (t && t.tagName === 'IMG' && t.closest && t.closest('.scs-stage, .msg-stage, .lt-stage')) {
            lightboxImg.src = t.src;
            lightbox.classList.add('is-open');
          } else if (t === lightbox || t === lightboxImg) {
            lightbox.classList.remove('is-open');
          }
        });
        document.addEventListener('keydown', (e) => {
          if (e.key === 'Escape') lightbox.classList.remove('is-open');
        });
      });
    </script>
  </body>
</html>
