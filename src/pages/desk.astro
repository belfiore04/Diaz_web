---
import Layout from '../layouts/Layout.astro';

// 桌面 · Table — 真翻书 demo
// 每页绕"左边轴" rotateY -180° 翻起,backface-visibility:hidden 让翻过的页自动让位
// 翻页:键盘 ← → / 点击页面左右半边 / 触屏左右滑
const spreads = [
  { src: '/desk-cover.png',  label: '封面' },
  { src: '/desk-page12.png', label: '目录' },
  { src: '/desk-page34.png', label: '阿卡贝拉' },
];
const total = spreads.length;
---

<Layout
  title="桌面 · Table — 李多迪"
  bgImage="/desk-bg.png"
  navColor="#fff"
  logoColor="#E50000"
  highlightColor="#0050FF"
>
  <style define:vars={{ total: String(total) }}>
    .desk-viewport {
      position: relative;
      width: 100%;
      height: 100vh;
      overflow: hidden;
    }
    /* 翻书舞台 — 3D perspective 容器 */
    .book-stage {
      position: relative;
      width: 100%;
      height: 100%;
      perspective: 2600px;
      perspective-origin: 30% 50%;
    }
    /* 每张纸:堆叠在同一位置,以左边为轴翻起 */
    .paper {
      position: absolute;
      left: 50%;
      top: 50%;
      width: 92%;
      aspect-ratio: 1968 / 1440;
      max-height: 88vh;
      margin: 0;
      transform: translate(-50%, -50%) rotateY(0deg);
      transform-origin: 0% 50%;
      transform-style: preserve-3d;
      transition: transform 0.95s cubic-bezier(.45, .0, .2, 1),
                  box-shadow 0.95s ease;
      backface-visibility: hidden;
      background: #FAFAFA;
      background-repeat: no-repeat;
      background-size: 100% 100%;
      background-position: center;
      box-shadow: 0 24px 60px rgba(0, 0, 0, 0.35),
                  0 4px 12px rgba(0, 0, 0, 0.18);
      border-radius: 2px;
      will-change: transform, box-shadow;
    }
    /* z-index:cover 在最上(data-i=0),后面页层层在下 */
    .paper[data-i="0"] { z-index: 30; }
    .paper[data-i="1"] { z-index: 20; }
    .paper[data-i="2"] { z-index: 10; }

    /* 翻过的页:rotateY -180° */
    .paper[data-flipped="true"] {
      transform: translate(-50%, -50%) rotateY(-180deg);
      box-shadow: 0 24px 80px rgba(0, 0, 0, 0.5);
    }

    /* 左右点击区域,占整 viewport 各一半 */
    .click-prev, .click-next {
      position: absolute;
      top: 0;
      height: 100%;
      width: 50%;
      z-index: 50;
      background: transparent;
      border: 0;
      padding: 0;
      cursor: w-resize;
    }
    .click-prev { left: 0; }
    .click-next { right: 0; cursor: e-resize; }
    .click-prev:disabled, .click-next:disabled { cursor: default; }

    /* 页码 */
    .pager {
      position: absolute;
      bottom: 3.5vh;
      right: 2.5vw;
      z-index: 60;
      color: #fff;
      font-family: 'Kameron', serif;
      font-weight: 700;
      font-size: clamp(14px, 1.2vw, 22px);
      letter-spacing: 0.18em;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.55);
      user-select: none;
      pointer-events: none;
    }
    .hint {
      position: absolute;
      bottom: 3.5vh;
      left: 50%;
      transform: translateX(-50%);
      z-index: 60;
      color: rgba(255, 255, 255, 0.85);
      font-family: 'Kameron', serif;
      font-size: clamp(11px, 0.9vw, 16px);
      letter-spacing: 0.12em;
      text-shadow: 0 2px 6px rgba(0, 0, 0, 0.5);
      user-select: none;
      pointer-events: none;
      transition: opacity 0.5s ease;
    }
    .hint.is-hidden { opacity: 0; }
  </style>

  <section class="desk-viewport">
    <div class="book-stage" id="book-stage">
      {spreads.map((s, i) => (
        <div class="paper" data-i={i} style={`background-image: url('${s.src}')`}></div>
      ))}
    </div>
    <button class="click-prev" aria-label="上一页" id="btn-prev"></button>
    <button class="click-next" aria-label="下一页" id="btn-next"></button>
    <div class="pager" id="pager">1 / {total}</div>
    <div class="hint" id="hint">← / →  或 点击左右 翻页</div>
  </section>

  <script is:inline define:vars={{ total }}>
    (() => {
      const papers = document.querySelectorAll('.paper');
      const pager = document.getElementById('pager');
      const hint = document.getElementById('hint');
      const prev = document.getElementById('btn-prev');
      const next = document.getElementById('btn-next');

      const hashIdx = parseInt((location.hash || '').replace('#', ''), 10);
      let cur = Number.isFinite(hashIdx) ? Math.max(0, Math.min(total - 1, hashIdx)) : 0;

      function render() {
        papers.forEach((p, i) => {
          // cur 之前(<cur)的页都翻过去,cur 及以后(>=cur)的页平躺
          p.dataset.flipped = i < cur ? 'true' : 'false';
        });
        pager.textContent = `${cur + 1} / ${total}`;
        prev.disabled = cur === 0;
        next.disabled = cur === total - 1;
        history.replaceState(null, '', '#' + cur);
      }

      function goto(n) {
        const nxt = Math.max(0, Math.min(total - 1, n));
        if (nxt === cur) return;
        cur = nxt;
        render();
      }

      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight') goto(cur + 1);
        else if (e.key === 'ArrowLeft') goto(cur - 1);
      });

      prev.addEventListener('click', () => goto(cur - 1));
      next.addEventListener('click', () => goto(cur + 1));

      // 触屏滑动
      let touchX = null;
      document.addEventListener('touchstart', (e) => { touchX = e.touches[0].clientX; }, { passive: true });
      document.addEventListener('touchend', (e) => {
        if (touchX == null) return;
        const dx = e.changedTouches[0].clientX - touchX;
        if (Math.abs(dx) > 40) goto(cur + (dx < 0 ? 1 : -1));
        touchX = null;
      }, { passive: true });

      render();
      setTimeout(() => hint.classList.add('is-hidden'), 4000);

      // 截图演示用:?flipping=N 让第 N 页停在翻到一半的状态(给静态截图看 3D 效果)
      const flipParam = new URLSearchParams(location.search).get('flipping');
      if (flipParam !== null) {
        const idx = Math.max(0, Math.min(total - 1, parseInt(flipParam, 10) || 0));
        papers[idx].style.transition = 'none';
        papers[idx].style.transform = 'translate(-50%, -50%) rotateY(-55deg)';
        papers[idx].style.boxShadow = '-30px 24px 80px rgba(0, 0, 0, 0.55)';
      }
    })();
  </script>
</Layout>
