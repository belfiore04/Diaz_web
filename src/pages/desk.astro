---
import Layout from '../layouts/Layout.astro';

// 桌面 · Table — 杂志翻页 demo
// 三个 spread 横向铺开,carousel 翻页,键盘 ← → / 点击左右 / 页码
// PNG 是从 figma TB内容Page > {cover, page1-2, page3-4} render @2x 来的
const spreads = [
  { src: '/desk-cover.png',  label: '封面' },
  { src: '/desk-page12.png', label: '目录' },
  { src: '/desk-page34.png', label: '阿卡贝拉' },
];
const total = spreads.length;
---

<Layout
  title="桌面 · Table — 李多迪"
  bgImage="/desk-bg.png"
  navColor="#fff"
  logoColor="#E50000"
  highlightColor="#0050FF"
>
  <style define:vars={{ totalPct: `${total * 100}%`, slidePct: `${100 / total}%` }}>
    .desk-viewport {
      position: relative;
      width: 100%;
      height: 100vh;
      overflow: hidden;
      perspective: 2400px;
      container-type: inline-size;
    }
    .book-track {
      display: flex;
      width: var(--totalPct);
      height: 100%;
      transition: transform 0.7s cubic-bezier(.5, .0, .2, 1);
      transform-style: preserve-3d;
    }
    .spread {
      flex: 0 0 var(--slidePct);
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
    }
    /* 每个 spread 内的"纸" — 一张白纸贴在桌上 */
    .page {
      width: 92%;
      aspect-ratio: 1968 / 1440;
      max-height: 88vh;
      background: #FAFAFA;
      background-repeat: no-repeat;
      background-position: center;
      background-size: 100% 100%;
      box-shadow:
        0 24px 60px rgba(0, 0, 0, 0.35),
        0 4px 12px rgba(0, 0, 0, 0.18);
      border-radius: 2px;
    }

    /* 左右点击区域,占整 viewport 各一半,透明 */
    .click-prev, .click-next {
      position: absolute;
      top: 0;
      height: 100%;
      width: 50%;
      z-index: 5;
      background: transparent;
      border: 0;
      padding: 0;
      cursor: w-resize;
    }
    .click-prev { left: 0; }
    .click-next { right: 0; cursor: e-resize; }
    .click-prev:disabled, .click-next:disabled { cursor: default; }

    /* 页码 */
    .pager {
      position: absolute;
      bottom: 3.5vh;
      right: 2.5vw;
      z-index: 10;
      color: #fff;
      font-family: 'Kameron', serif;
      font-weight: 700;
      font-size: clamp(14px, 1.2vw, 22px);
      letter-spacing: 0.18em;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.55);
      user-select: none;
      pointer-events: none;
    }
    /* 翻页提示,首次进入显示 */
    .hint {
      position: absolute;
      bottom: 3.5vh;
      left: 50%;
      transform: translateX(-50%);
      z-index: 10;
      color: rgba(255, 255, 255, 0.85);
      font-family: 'Kameron', serif;
      font-size: clamp(11px, 0.9vw, 16px);
      letter-spacing: 0.12em;
      text-shadow: 0 2px 6px rgba(0, 0, 0, 0.5);
      user-select: none;
      pointer-events: none;
      transition: opacity 0.5s ease;
    }
    .hint.is-hidden { opacity: 0; }
  </style>

  <section class="desk-viewport" id="desk-viewport">
    <div class="book-track" id="book-track">
      {spreads.map((s, i) => (
        <div class="spread" data-i={i}>
          <div class="page" style={`background-image: url('${s.src}')`}></div>
        </div>
      ))}
    </div>
    <button class="click-prev" aria-label="上一页" id="btn-prev"></button>
    <button class="click-next" aria-label="下一页" id="btn-next"></button>
    <div class="pager" id="pager">1 / {total}</div>
    <div class="hint" id="hint">← / →  或 点击左右 翻页</div>
  </section>

  <script is:inline define:vars={{ total }}>
    (() => {
      const track = document.getElementById('book-track');
      const pager = document.getElementById('pager');
      const hint = document.getElementById('hint');
      const prev = document.getElementById('btn-prev');
      const next = document.getElementById('btn-next');

      const hashIdx = parseInt((location.hash || '').replace('#', ''), 10);
      let i = Number.isFinite(hashIdx) ? Math.max(0, Math.min(total - 1, hashIdx)) : 0;
      let hintShown = false;

      const slidePct = 100 / total;

      function render() {
        track.style.transform = `translateX(-${i * slidePct}%)`;
        pager.textContent = `${i + 1} / ${total}`;
        prev.disabled = i === 0;
        next.disabled = i === total - 1;
        history.replaceState(null, '', '#' + i);
        if (hintShown) hint.classList.add('is-hidden');
        hintShown = true;
      }

      function goto(n) {
        const next = Math.max(0, Math.min(total - 1, n));
        if (next === i) return;
        i = next;
        render();
      }

      document.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight') goto(i + 1);
        else if (e.key === 'ArrowLeft') goto(i - 1);
      });

      prev.addEventListener('click', () => goto(i - 1));
      next.addEventListener('click', () => goto(i + 1));

      // 触屏滑动
      let touchX = null;
      document.addEventListener('touchstart', (e) => { touchX = e.touches[0].clientX; }, { passive: true });
      document.addEventListener('touchend', (e) => {
        if (touchX == null) return;
        const dx = e.changedTouches[0].clientX - touchX;
        if (Math.abs(dx) > 40) goto(i + (dx < 0 ? 1 : -1));
        touchX = null;
      }, { passive: true });

      render();
      hintShown = true;  // 初次 render 不算"用户翻了",让 hint 保留 4 秒后再淡出
      setTimeout(() => hint.classList.add('is-hidden'), 4000);
    })();
  </script>
</Layout>
