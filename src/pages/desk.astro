---
import Layout from '../layouts/Layout.astro';

// 桌面 · Table
// 初始:玻璃桌 + 一本杂志贴图(figma TB 主页 1:1 复刻)
// 点击杂志 → 全屏覆盖,StPageFlip 真曲面翻页
// ESC / 关闭按钮 → 收回桌面
---

<Layout
  title="桌面 · Table — 李多迪"
  bgImage="/desk/TB-bg.webp"
  navColor="#fff"
  logoColor="#E50000"
  highlightColor="#0050FF"
>
  <style>
    /* 桌面主视图 — 杂志贴图按 figma 1:1 定位
       figma TB 主页 2560×1440,杂志贴图 893×854 @ (1280,293 相对 frame)
       nav ~520px,主区 2040
       相对主区 left=37.3% top=20.3% width=43.8%
    */
    .desk-room {
      position: relative;
      width: 100%;
      height: 100vh;
      overflow: hidden;
    }
    .magazine-sticker {
      position: absolute;
      left: 37.3%;
      top: 20.3%;
      width: 43.8%;
      padding: 0;
      border: 0;
      background: transparent;
      cursor: pointer;
      transition: transform 0.4s cubic-bezier(0.2, 0.6, 0.2, 1), filter 0.4s ease;
      transform-origin: 50% 50%;
      will-change: transform, filter;
      filter: drop-shadow(0 12px 24px rgba(0, 0, 0, 0.25));
    }
    .magazine-sticker:hover {
      transform: scale(1.025) translateY(-4px);
      filter: drop-shadow(0 20px 36px rgba(0, 0, 0, 0.35));
    }
    .magazine-sticker img {
      display: block;
      width: 100%;
      height: auto;
      pointer-events: none;
    }
    .sticker-hint {
      position: absolute;
      left: 50%;
      bottom: 8vh;
      transform: translateX(-50%);
      color: rgba(255, 255, 255, 0.9);
      font-family: 'Kameron', serif;
      font-size: clamp(13px, 1vw, 18px);
      letter-spacing: 0.18em;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.55);
      pointer-events: none;
      user-select: none;
      opacity: 0;
      animation: hint-fade-in 1.2s 0.6s ease forwards;
    }
    @keyframes hint-fade-in { to { opacity: 1; } }

    /* 翻书全屏遮罩 */
    .book-overlay {
      position: fixed;
      inset: 0;
      z-index: 9000;
      background: rgba(8, 12, 10, 0);
      backdrop-filter: blur(0px);
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
      transition: background 0.5s ease, backdrop-filter 0.5s ease;
    }
    .book-overlay.is-open {
      background: rgba(8, 12, 10, 0.88);
      backdrop-filter: blur(8px);
      pointer-events: auto;
    }
    .book-stage {
      position: relative;
      opacity: 0;
      transform: scale(0.4);
      transition: opacity 0.55s 0.1s ease, transform 0.6s 0.05s cubic-bezier(0.2, 0.6, 0.2, 1);
    }
    .book-overlay.is-open .book-stage { opacity: 1; transform: scale(1); }
    #book-canvas {
      /* 鼠标在书上变放大镜:暗示单击放大 */
      cursor: zoom-in;
    }
    /* HTML 模式下每页的 DOM 容器 */
    .bf-page {
      width: 100%;
      height: 100%;
      background: #FAFAFA;
      overflow: hidden;
      user-select: none;
    }
    .bf-page img {
      display: block;
      width: 100%;
      height: 100%;
      object-fit: cover;
      pointer-events: none;
      -webkit-user-drag: none;
    }

    /* 顶部右关闭 */
    .book-close {
      position: absolute;
      top: 3vh;
      right: 3vw;
      z-index: 10;
      width: 48px;
      height: 48px;
      border: 0;
      background: rgba(255, 255, 255, 0.08);
      color: #fff;
      font-family: 'Kameron', serif;
      font-size: 22px;
      line-height: 1;
      border-radius: 50%;
      cursor: pointer;
      backdrop-filter: blur(10px);
      transition: background 0.2s ease, transform 0.2s ease;
    }
    .book-close:hover { background: rgba(255, 255, 255, 0.18); transform: scale(1.08); }

    /* 左右翻页热区:占两侧屏幕剩余空间(书外),指针箭头 */
    .book-flank {
      position: absolute;
      top: 0;
      height: 100%;
      width: 20vw;
      z-index: 5;
      cursor: w-resize;
      background: transparent;
      border: 0;
      padding: 0;
      transition: background 0.2s ease;
    }
    .book-flank-left  { left: 0; }
    .book-flank-right { right: 0; cursor: e-resize; }
    .book-flank:hover { background: rgba(255, 255, 255, 0.02); }
    .book-flank:disabled { cursor: default; }
    .book-flank-arrow {
      position: absolute;
      top: 50%;
      transform: translateY(-50%);
      color: rgba(255, 255, 255, 0.7);
      font-family: 'Kameron', serif;
      font-size: clamp(36px, 4vw, 56px);
      line-height: 1;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.2s ease;
    }
    .book-flank:hover .book-flank-arrow,
    .book-flank:focus-visible .book-flank-arrow { opacity: 1; }
    .book-flank-left  .book-flank-arrow { left: 2vw; }
    .book-flank-right .book-flank-arrow { right: 2vw; }
    .book-flank:disabled .book-flank-arrow { opacity: 0.15; }

    /* 页码 + 提示 */
    .book-pager {
      position: absolute;
      left: 50%;
      bottom: 4vh;
      transform: translateX(-50%);
      color: rgba(255, 255, 255, 0.8);
      font-family: 'Kameron', serif;
      font-size: 14px;
      letter-spacing: 0.18em;
      user-select: none;
      pointer-events: none;
      display: flex;
      gap: 1.5em;
      align-items: baseline;
    }
    .book-pager .hint {
      color: rgba(255, 255, 255, 0.4);
      font-size: 11px;
      letter-spacing: 0.12em;
    }

    /* lightbox 放大单页 */
    .book-zoom {
      position: fixed;
      inset: 0;
      z-index: 9500;
      background: rgba(0, 0, 0, 0.96);
      display: none;
      align-items: center;
      justify-content: center;
      cursor: zoom-out;
      opacity: 0;
      transition: opacity 0.25s ease;
    }
    .book-zoom.is-open { display: flex; opacity: 1; }
    .book-zoom img {
      max-width: 96vw;
      max-height: 96vh;
      object-fit: contain;
      border-radius: 4px;
      box-shadow: 0 30px 100px rgba(0, 0, 0, 0.8);
    }
    .book-zoom-pair {
      display: flex;
      gap: 4px;
      max-width: 96vw;
      max-height: 96vh;
    }
    .book-zoom-pair img {
      max-width: 48vw;
      max-height: 96vh;
      object-fit: contain;
    }
  </style>

  <section class="desk-room">
    <button class="magazine-sticker" id="magazine-sticker" aria-label="打开杂志">
      <img src="/desk/magazine-sticker.webp" alt="桌上的一本杂志" />
    </button>
    <div class="sticker-hint">点击杂志,翻开看看</div>
  </section>

  <!-- 翻书 overlay -->
  <div class="book-overlay" id="book-overlay" aria-hidden="true">
    <button class="book-close" id="book-close" aria-label="关闭">×</button>

    <!-- 左右翻页热区 -->
    <button class="book-flank book-flank-left" id="flank-prev" aria-label="上一页">
      <span class="book-flank-arrow">‹</span>
    </button>
    <button class="book-flank book-flank-right" id="flank-next" aria-label="下一页">
      <span class="book-flank-arrow">›</span>
    </button>

    <div class="book-stage" id="book-stage">
      <div id="book-canvas"></div>
    </div>

    <div class="book-pager" id="book-pager">
      <span id="pager-num">1 / 1</span>
      <span class="hint">← / →  单击放大  ESC 关闭</span>
    </div>
  </div>

  <!-- 放大 lightbox -->
  <div class="book-zoom" id="book-zoom" aria-hidden="true">
    <div class="book-zoom-pair" id="book-zoom-pair"></div>
  </div>

  <script is:inline src="/vendor/page-flip.browser.js"></script>

  <script is:inline>
    const PageFlip = window.St.PageFlip;

    // 39 单页 = 1 cover + 1 cover-inside + 1 扉页 + 17×2 内容 + 2 结尾;前面加 blank 让画框 16:9
    const pageImages = [
      '/desk/page--blank.webp',
      '/desk/page-00-cover.webp',
      '/desk/page-01-cover-inside.webp',
      '/desk/page-02-feiye.webp',
    ];
    for (let i = 3; i <= 38; i++) {
      pageImages.push(`/desk/page-${String(i).padStart(2, '0')}.webp`);
    }

    const sticker = document.getElementById('magazine-sticker');
    const overlay = document.getElementById('book-overlay');
    const canvasEl = document.getElementById('book-canvas');
    const closeBtn = document.getElementById('book-close');
    const pagerNum = document.getElementById('pager-num');
    const flankPrev = document.getElementById('flank-prev');
    const flankNext = document.getElementById('flank-next');
    const zoom = document.getElementById('book-zoom');
    const zoomPair = document.getElementById('book-zoom-pair');

    // 移出 site-main stacking context
    document.body.appendChild(overlay);
    document.body.appendChild(zoom);

    let pageFlip = null;
    let isOpen = false;
    let curPage = 0;

    // 预加载所有 webp,翻页时下层图不会未解码
    let preloadDone = null;
    function preloadAll() {
      if (preloadDone) return preloadDone;
      preloadDone = Promise.all(pageImages.map((src) => new Promise((res) => {
        const img = new Image();
        img.onload = () => res();
        img.onerror = () => res();
        img.src = src;
      })));
      return preloadDone;
    }

    function computeBookSize() {
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const maxW = vw * 0.88;   // 留 6vw 给左右翻页箭头
      const maxH = vh * 0.88;
      const ratio = 2560 / 1440;
      const bookW = Math.min(maxW, maxH * ratio);
      const bookH = bookW / ratio;
      return { width: Math.floor(bookW / 2), height: Math.floor(bookH) };
    }

    function updatePager(idx) {
      curPage = idx;
      const cur = Math.max(1, idx);
      pagerNum.textContent = `${cur} / ${pageImages.length - 1}`;
      flankPrev.disabled = (idx <= 0);
      flankNext.disabled = (idx >= pageImages.length - 1);
    }

    // 用 HTML 模式 — canvas 模式翻页时不 clearRect 会有像素残留(两页重叠)
    // HTML 模式每页是真实 DOM,浏览器原生处理图层,无残留
    function buildPagesDom() {
      canvasEl.innerHTML = '';
      pageImages.forEach((src, i) => {
        const pg = document.createElement('div');
        pg.className = 'bf-page';
        pg.dataset.idx = String(i);
        const im = document.createElement('img');
        im.src = src;
        im.alt = '';
        im.draggable = false;
        pg.appendChild(im);
        canvasEl.appendChild(pg);
      });
    }

    function initBook() {
      if (pageFlip) return;
      const { width, height } = computeBookSize();
      buildPagesDom();
      pageFlip = new PageFlip(canvasEl, {
        width,
        height,
        size: 'fixed',
        showCover: false,
        flippingTime: 900,
        drawShadow: false,        // 关掉书脊 + 翻页阴影
        usePortrait: false,       // 强制双页 landscape,画框 16:9
        mobileScrollSupport: false,
        swipeDistance: 30,
        startPage: 0,
      });
      pageFlip.loadFromHTML(canvasEl.querySelectorAll('.bf-page'));
      pageFlip.on('flip', (e) => updatePager(e.data));
      updatePager(0);
    }

    function openBook() {
      if (isOpen) return;
      isOpen = true;
      overlay.setAttribute('aria-hidden', 'false');
      overlay.classList.add('is-open');
      preloadAll().then(() => initBook());
    }
    function closeBook() {
      if (!isOpen) return;
      isOpen = false;
      overlay.classList.remove('is-open');
      overlay.setAttribute('aria-hidden', 'true');
      closeZoom();
    }

    // 翻页 — 键盘 / 按钮 / 屏幕左右半边
    function flipPrev() { if (pageFlip && curPage > 0) pageFlip.flipPrev(); }
    function flipNext() { if (pageFlip && curPage < pageImages.length - 1) pageFlip.flipNext(); }

    sticker.addEventListener('click', openBook);
    closeBtn.addEventListener('click', closeBook);
    flankPrev.addEventListener('click', flipPrev);
    flankNext.addEventListener('click', flipNext);
    // 点击蒙层(不是 stage 区域)关闭
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeBook();
    });
    document.addEventListener('keydown', (e) => {
      if (!isOpen) return;
      if (e.key === 'Escape') {
        if (zoom.classList.contains('is-open')) closeZoom();
        else closeBook();
      }
      else if (e.key === 'ArrowLeft')  flipPrev();
      else if (e.key === 'ArrowRight') flipNext();
    });

    // 短按放大:capture 阶段拦 mouseup,如果位移小+时间短 → 放大并阻止 PageFlip 的翻页 handler
    // 拖拽(超过位移阈值)放行给 PageFlip 处理翻页
    let downX = 0, downY = 0, downT = 0;
    const CLICK_MOVE_THRESHOLD = 5;
    const CLICK_TIME_THRESHOLD = 250;
    canvasEl.addEventListener('mousedown', (e) => {
      downX = e.clientX; downY = e.clientY; downT = Date.now();
    }, true);
    canvasEl.addEventListener('mouseup', (e) => {
      const dx = Math.abs(e.clientX - downX);
      const dy = Math.abs(e.clientY - downY);
      const dt = Date.now() - downT;
      if (dx < CLICK_MOVE_THRESHOLD && dy < CLICK_MOVE_THRESHOLD && dt < CLICK_TIME_THRESHOLD) {
        // 短按:阻止 PageFlip 翻页,改成放大
        e.stopImmediatePropagation();
        e.preventDefault();
        openZoom();
      }
    }, true); // capture phase 在 PageFlip listener 之前

    // 双击 book canvas → 放大当前 spread(左右两页拼一起看)
    function openZoom() {
      // 当前可见 spread 的左右页
      // PageFlip flip event 的 data 是新的"右页"index;左页 = right - 1
      // 不过初始 curPage = 0 时显示 spread = [0(blank), 1(cover)]
      // 通用规则:spread 左 = curPage 的偶数对(向下取偶),右 = 左 + 1
      let leftIdx, rightIdx;
      if (curPage % 2 === 0) { leftIdx = curPage; rightIdx = curPage + 1; }
      else                   { leftIdx = curPage - 1; rightIdx = curPage; }
      leftIdx = Math.max(0, Math.min(pageImages.length - 1, leftIdx));
      rightIdx = Math.max(0, Math.min(pageImages.length - 1, rightIdx));

      zoomPair.innerHTML = '';
      const showLeft = leftIdx > 0; // blank 占位不显示
      if (showLeft) {
        const il = document.createElement('img');
        il.src = pageImages[leftIdx];
        zoomPair.appendChild(il);
      }
      const ir = document.createElement('img');
      ir.src = pageImages[rightIdx];
      zoomPair.appendChild(ir);
      // 只一张图时撑满
      zoomPair.style.justifyContent = showLeft ? 'center' : 'center';

      zoom.classList.add('is-open');
      zoom.setAttribute('aria-hidden', 'false');
    }
    function closeZoom() {
      zoom.classList.remove('is-open');
      zoom.setAttribute('aria-hidden', 'true');
    }
    zoom.addEventListener('click', closeZoom);

    // 截图调试:?open=1&page=N
    const qp = new URLSearchParams(location.search);
    if (qp.get('open') === '1') {
      setTimeout(() => {
        openBook();
        const p = parseInt(qp.get('page') || '0', 10);
        if (p > 0) setTimeout(() => pageFlip && pageFlip.flip(p), 800);
      }, 100);
    }

    // resize 重建
    let resizeTimer;
    window.addEventListener('resize', () => {
      if (!pageFlip || !isOpen) return;
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => {
        const cur = curPage;
        try { pageFlip.destroy(); } catch {}
        pageFlip = null;
        const { width, height } = computeBookSize();
        buildPagesDom();
        pageFlip = new PageFlip(canvasEl, {
          width, height, size: 'fixed',
          showCover: false, flippingTime: 900,
          drawShadow: false, usePortrait: false,
          mobileScrollSupport: false, swipeDistance: 30,
          startPage: cur,
        });
        pageFlip.loadFromHTML(canvasEl.querySelectorAll('.bf-page'));
        pageFlip.on('flip', (e) => updatePager(e.data));
      }, 200);
    });
  </script>
</Layout>
