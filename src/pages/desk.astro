---
import Layout from '../layouts/Layout.astro';

// 桌面 · Table
// 初始:玻璃桌 + 一本杂志贴图(figma TB 主页 1:1 复刻)
// 点击杂志 → 全屏覆盖,StPageFlip 真曲面翻页
// ESC / 关闭按钮 → 收回桌面
---

<Layout
  title="桌面 · Table — 李多迪"
  bgImage="/desk/TB-bg.png"
  navColor="#fff"
  logoColor="#E50000"
  highlightColor="#0050FF"
>
  <style>
    /* 桌面主视图 — 杂志贴图按 figma 1:1 定位
       figma TB 主页 2560×1440,杂志贴图 1038×993 @ (1328,224 相对 frame)
       nav 区在 figma 左 ~520px (20.3%),主区右 80%
       杂志相对主区 left = (1328-520)/2040 ≈ 39.6%, top = 224/1440 ≈ 15.6%
       width = 1038/2040 ≈ 51%
    */
    .desk-room {
      position: relative;
      width: 100%;
      height: 100vh;
      overflow: hidden;
    }
    .magazine-sticker {
      position: absolute;
      left: 39.6%;
      top: 15.6%;
      width: 51%;
      padding: 0;
      border: 0;
      background: transparent;
      cursor: pointer;
      transition: transform 0.4s cubic-bezier(0.2, 0.6, 0.2, 1), filter 0.4s ease;
      transform-origin: 50% 50%;
      will-change: transform, filter;
      filter: drop-shadow(0 12px 24px rgba(0, 0, 0, 0.25));
    }
    .magazine-sticker:hover {
      transform: scale(1.025) translateY(-4px);
      filter: drop-shadow(0 20px 36px rgba(0, 0, 0, 0.35));
    }
    .magazine-sticker img {
      display: block;
      width: 100%;
      height: auto;
      pointer-events: none;
    }
    .sticker-hint {
      position: absolute;
      left: 50%;
      bottom: 8vh;
      transform: translateX(-50%);
      color: rgba(255, 255, 255, 0.9);
      font-family: 'Kameron', serif;
      font-size: clamp(13px, 1vw, 18px);
      letter-spacing: 0.18em;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.55);
      pointer-events: none;
      user-select: none;
      opacity: 0;
      animation: hint-fade-in 1.2s 0.6s ease forwards;
    }
    @keyframes hint-fade-in { to { opacity: 1; } }

    /* 翻书全屏遮罩 */
    .book-overlay {
      position: fixed;
      inset: 0;
      z-index: 9000;
      background: rgba(8, 12, 10, 0);
      backdrop-filter: blur(0px);
      display: flex;
      align-items: center;
      justify-content: center;
      pointer-events: none;
      transition: background 0.5s ease, backdrop-filter 0.5s ease;
    }
    .book-overlay.is-open {
      background: rgba(8, 12, 10, 0.88);
      backdrop-filter: blur(8px);
      pointer-events: auto;
    }
    .book-stage {
      position: relative;
      opacity: 0;
      transform: scale(0.4);
      transition: opacity 0.55s 0.1s ease, transform 0.6s 0.05s cubic-bezier(0.2, 0.6, 0.2, 1);
    }
    .book-overlay.is-open .book-stage {
      opacity: 1;
      transform: scale(1);
    }
    #book-canvas {
      box-shadow: 0 30px 100px rgba(0, 0, 0, 0.65);
    }
    .book-close {
      position: absolute;
      top: 3vh;
      right: 3vw;
      z-index: 10;
      width: 48px;
      height: 48px;
      border: 0;
      background: rgba(255, 255, 255, 0.08);
      color: #fff;
      font-family: 'Kameron', serif;
      font-size: 22px;
      line-height: 1;
      border-radius: 50%;
      cursor: pointer;
      backdrop-filter: blur(10px);
      transition: background 0.2s ease, transform 0.2s ease;
    }
    .book-close:hover {
      background: rgba(255, 255, 255, 0.18);
      transform: scale(1.08);
    }
    .book-pager {
      position: absolute;
      left: 50%;
      bottom: 4vh;
      transform: translateX(-50%);
      color: rgba(255, 255, 255, 0.8);
      font-family: 'Kameron', serif;
      font-size: 14px;
      letter-spacing: 0.18em;
      user-select: none;
      pointer-events: none;
    }
  </style>

  <section class="desk-room">
    <button class="magazine-sticker" id="magazine-sticker" aria-label="打开杂志">
      <img src="/desk/magazine-sticker.png" alt="桌上的一本杂志" />
    </button>
    <div class="sticker-hint">点击杂志,翻开看看</div>
  </section>

  <!-- 翻书 overlay -->
  <div class="book-overlay" id="book-overlay" aria-hidden="true">
    <button class="book-close" id="book-close" aria-label="关闭">×</button>
    <div class="book-stage" id="book-stage">
      <div id="book-canvas"></div>
    </div>
    <div class="book-pager" id="book-pager"></div>
  </div>

  <!-- StPageFlip UMD bundle:全局 St.PageFlip。
       直接 script src 引入,绕过 page-flip 包没有 ESM exports 字段导致 Vite resolve 失败 -->
  <script is:inline src="/vendor/page-flip.browser.js"></script>

  <script is:inline>
    const PageFlip = window.St.PageFlip;

    // 第 0 张是透明虚拟左页,让 cover 成为 spread 0 的右页 → 画框始终保持 16:9 双页比例
    // showCover:false 配合此,翻开后视觉是"杂志放在桌上,右边封面 / 左侧空"
    const pageImages = [
      '/desk/page--blank.png',
      '/desk/page-00-cover.png',
      '/desk/page-01-cover-inside.png',
      '/desk/page-02-feiye.png',
      '/desk/page-03.png',
      '/desk/page-04.png',
      '/desk/page-05.png',
      '/desk/page-06.png',
      '/desk/page-07.png',
      '/desk/page-08.png',
      '/desk/page-09.png',
      '/desk/page-10.png',
      '/desk/page-11.png',
      '/desk/page-12.png',
      '/desk/page-13.png',
      '/desk/page-14.png',
      '/desk/page-15.png',
      '/desk/page-16.png',
      '/desk/page-17.png',
      '/desk/page-18.png',
      '/desk/page-19.png',
      '/desk/page-20.png',
      '/desk/page-21.png',
      '/desk/page-22.png',
      '/desk/page-23.png',
      '/desk/page-24.png',
    ];

    const sticker = document.getElementById('magazine-sticker');
    const overlay = document.getElementById('book-overlay');
    const canvasEl = document.getElementById('book-canvas');
    const closeBtn = document.getElementById('book-close');
    const pagerEl = document.getElementById('book-pager');
    // 把 overlay 移到 body 直接子级,逃离 site-main 的 stacking context
    document.body.appendChild(overlay);

    let pageFlip = null;
    let isOpen = false;

    function computeBookSize() {
      // 单页基准 1280×1440,书展开后 2560×1440 ≈ 16:9
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const maxW = vw * 0.92;
      const maxH = vh * 0.88;
      const ratio = 2560 / 1440;
      let bookW = Math.min(maxW, maxH * ratio);
      let bookH = bookW / ratio;
      return { width: Math.floor(bookW / 2), height: Math.floor(bookH) };
    }

    // 预加载所有图,确保翻页时下层页已 ready,不出现"翻页中两页内容叠在一起"的问题
    let preloadDone = null;
    function preloadAll() {
      if (preloadDone) return preloadDone;
      preloadDone = Promise.all(pageImages.map((src) => new Promise((res) => {
        const img = new Image();
        img.onload = () => res();
        img.onerror = () => res();
        img.src = src;
      })));
      return preloadDone;
    }

    function initBook() {
      if (pageFlip) return;
      const { width, height } = computeBookSize();
      pageFlip = new PageFlip(canvasEl, {
        width,
        height,
        size: 'fixed',
        showCover: false,
        flippingTime: 900,
        drawShadow: false,          // ← 关掉书脊中央 + 翻页阴影,jun 不要
        usePortrait: false,
        mobileScrollSupport: false,
        swipeDistance: 30,
        startPage: 0,
      });
      pageFlip.loadFromImages(pageImages);
      pageFlip.on('flip', (e) => {
        const cur = Math.max(1, e.data);
        pagerEl.textContent = `${cur} / ${pageImages.length - 1}`;
      });
      pagerEl.textContent = `1 / ${pageImages.length - 1}`;
    }

    function openBook() {
      if (isOpen) return;
      isOpen = true;
      overlay.setAttribute('aria-hidden', 'false');
      overlay.classList.add('is-open');
      // 预加载完成后再 init,避免翻页时下层 image 还没解码出现重叠
      preloadAll().then(() => initBook());
    }

    function closeBook() {
      if (!isOpen) return;
      isOpen = false;
      overlay.classList.remove('is-open');
      overlay.setAttribute('aria-hidden', 'true');
    }

    sticker.addEventListener('click', openBook);
    closeBtn.addEventListener('click', closeBook);
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) closeBook();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && isOpen) closeBook();
    });
    // resize 时简单重建(rare path,destroy + 重新 init)
    let resizeTimer;
    // 截图用:?open=1 立刻打开;?page=N 跳到第 N 页
    const qp = new URLSearchParams(location.search);
    if (qp.get('open') === '1') {
      setTimeout(() => {
        openBook();
        const p = parseInt(qp.get('page') || '0', 10);
        if (p > 0 && pageFlip) {
          setTimeout(() => pageFlip.flip(p), 200);
        }
      }, 100);
    }

    window.addEventListener('resize', () => {
      if (!pageFlip || !isOpen) return;
      window.clearTimeout(resizeTimer);
      resizeTimer = window.setTimeout(() => {
        const curPage = pageFlip.getCurrentPageIndex?.() ?? 0;
        try { pageFlip.destroy(); } catch {}
        pageFlip = null;
        const { width, height } = computeBookSize();
        pageFlip = new PageFlip(canvasEl, {
          width, height,
          size: 'fixed',
          showCover: false,
          flippingTime: 900,
          maxShadowOpacity: 0.5,
          drawShadow: true,
          usePortrait: false,
          mobileScrollSupport: false,
          swipeDistance: 30,
          startPage: curPage,
        });
        pageFlip.loadFromImages(pageImages);
        pageFlip.on('flip', (e) => {
          pagerEl.textContent = `${e.data + 1} / ${pageImages.length}`;
        });
      }, 200);
    });
  </script>
</Layout>
