---
import Layout from '../layouts/Layout.astro';

// 桌面 · Table
// 初始:玻璃桌 + 杂志贴图;点击杂志 → 全屏覆盖打开杂志
// 翻页 = 自己手写 CSS 3D rotateY,静止 = 普通 img(字 1:1 清),只在翻页瞬间叠临时纸 transform
// 单击书 = lightbox 放大左右两页;键盘 ← / → / 屏幕热区 / 按钮翻页;ESC 关
---

<Layout
  title="桌面 · Table — 李多迪"
  bgImage="/desk/TB-bg.webp"
  navColor="#fff"
  logoColor="#E50000"
  highlightColor="#0050FF"
>
  <style>
    /* 桌面主视图 — 杂志贴图按 figma 1:1 (893×854 @ 1280,293) */
    .desk-room {
      position: relative;
      width: 100%;
      height: 100vh;
      overflow: hidden;
    }
    .magazine-sticker {
      position: absolute;
      left: 37.3%;
      top: 20.3%;
      width: 43.8%;
      padding: 0; border: 0; background: transparent;
      cursor: pointer;
      transition: transform 0.4s cubic-bezier(0.2, 0.6, 0.2, 1), filter 0.4s ease;
      transform-origin: 50% 50%;
      filter: drop-shadow(0 12px 24px rgba(0, 0, 0, 0.25));
    }
    .magazine-sticker:hover {
      transform: scale(1.025) translateY(-4px);
      filter: drop-shadow(0 20px 36px rgba(0, 0, 0, 0.35));
    }
    .magazine-sticker img {
      display: block; width: 100%; height: auto; pointer-events: none;
    }
    .sticker-hint {
      position: absolute;
      left: 50%; bottom: 8vh;
      transform: translateX(-50%);
      color: rgba(255, 255, 255, 0.9);
      font-family: 'Kameron', serif;
      font-size: clamp(13px, 1vw, 18px);
      letter-spacing: 0.18em;
      text-shadow: 0 2px 8px rgba(0, 0, 0, 0.55);
      pointer-events: none; user-select: none;
      opacity: 0; animation: hint-fade-in 1.2s 0.6s ease forwards;
    }
    @keyframes hint-fade-in { to { opacity: 1; } }

    /* 翻书全屏遮罩 */
    .book-overlay {
      position: fixed; inset: 0;
      z-index: 9000;
      background: rgba(8, 12, 10, 0);
      backdrop-filter: blur(0px);
      display: flex; align-items: center; justify-content: center;
      pointer-events: none;
      transition: background 0.5s ease, backdrop-filter 0.5s ease;
    }
    .book-overlay.is-open {
      background: rgba(8, 12, 10, 0.88);
      backdrop-filter: blur(8px);
      pointer-events: auto;
    }

    /* 关闭按钮 */
    .book-close {
      position: absolute; top: 3vh; right: 3vw;
      z-index: 10;
      width: 48px; height: 48px;
      border: 0;
      background: rgba(255, 255, 255, 0.08);
      color: #fff;
      font-family: 'Kameron', serif;
      font-size: 22px; line-height: 1;
      border-radius: 50%;
      cursor: pointer;
      backdrop-filter: blur(10px);
      transition: background 0.2s ease, transform 0.2s ease;
    }
    .book-close:hover { background: rgba(255, 255, 255, 0.18); transform: scale(1.08); }

    /* 左右翻页热区 — 占两侧屏幕剩余空间 */
    .book-flank {
      position: absolute;
      top: 0; height: 100%;
      width: 20vw;
      z-index: 5;
      background: transparent; border: 0; padding: 0;
      cursor: w-resize;
      transition: background 0.2s ease;
    }
    .book-flank-left  { left: 0; }
    .book-flank-right { right: 0; cursor: e-resize; }
    .book-flank:hover { background: rgba(255, 255, 255, 0.02); }
    .book-flank:disabled { cursor: default; }
    .book-flank-arrow {
      position: absolute;
      top: 50%; transform: translateY(-50%);
      color: rgba(255, 255, 255, 0.7);
      font-family: 'Kameron', serif;
      font-size: clamp(36px, 4vw, 56px);
      line-height: 1; pointer-events: none;
      opacity: 0;
      transition: opacity 0.2s ease;
    }
    .book-flank:hover .book-flank-arrow,
    .book-flank:focus-visible .book-flank-arrow { opacity: 1; }
    .book-flank-left  .book-flank-arrow { left: 2vw; }
    .book-flank-right .book-flank-arrow { right: 2vw; }
    .book-flank:disabled .book-flank-arrow { opacity: 0.15; }

    /* 书本舞台 */
    .book-stage {
      position: relative;
      opacity: 0;
      transform: scale(0.4);
      transition: opacity 0.55s 0.1s ease, transform 0.6s 0.05s cubic-bezier(0.2, 0.6, 0.2, 1);
      perspective: 2400px;
    }
    .book-overlay.is-open .book-stage {
      opacity: 1; transform: scale(1);
    }

    /* 书容器 — 16:9 双页 */
    .book-viewport {
      position: relative;
      width: var(--book-width, 80vw);
      height: var(--book-height, 45vw);
      max-width: 92vw;
      max-height: 88vh;
      display: flex;
      transform-style: preserve-3d;
      cursor: zoom-in;
      background: #FFFFFF;
      box-shadow: 0 20px 60px rgba(0, 0, 0, 0.45);
    }
    .bf-page {
      flex: 1;
      position: relative;
      overflow: hidden;
      background: #FFFFFF;
    }
    .bf-page img {
      display: block;
      width: 100%; height: 100%;
      object-fit: fill;
      user-select: none;
      -webkit-user-drag: none;
      /* 静止时无 transform → 字 1:1 清晰 */
    }

    /* 翻页临时纸:层叠在 spread 上方,backface 自动切面 */
    .flip-paper {
      position: absolute;
      top: 0;
      width: 50%;
      height: 100%;
      transform-style: preserve-3d;
      z-index: 10;
      pointer-events: none;
      will-change: transform;
    }
    .flip-paper .face {
      position: absolute;
      inset: 0;
      backface-visibility: hidden;
      -webkit-backface-visibility: hidden;
      overflow: hidden;
      background: #FFFFFF;
    }
    .flip-paper .face img {
      display: block;
      width: 100%; height: 100%;
      object-fit: fill;
      pointer-events: none;
    }
    .flip-paper .face.back { transform: rotateY(180deg); }

    /* 翻向左 — 下一页:纸挂在右半,绕左边翻 */
    .flip-paper.forward {
      right: 0;
      transform-origin: 0% 50%;
      animation: flip-forward 0.85s cubic-bezier(0.45, 0, 0.25, 1) forwards;
    }
    @keyframes flip-forward {
      0%   { transform: rotateY(0deg); }
      45%  { transform: rotateY(-78deg) translateZ(40px); }
      100% { transform: rotateY(-180deg); }
    }

    /* 翻向右 — 上一页:纸挂在左半,绕右边翻 */
    .flip-paper.backward {
      left: 0;
      transform-origin: 100% 50%;
      animation: flip-backward 0.85s cubic-bezier(0.45, 0, 0.25, 1) forwards;
    }
    @keyframes flip-backward {
      0%   { transform: rotateY(0deg); }
      45%  { transform: rotateY(78deg) translateZ(40px); }
      100% { transform: rotateY(180deg); }
    }

    /* 页码 + 提示 */
    .book-pager {
      position: absolute;
      left: 50%; bottom: 4vh;
      transform: translateX(-50%);
      color: rgba(255, 255, 255, 0.8);
      font-family: 'Kameron', serif;
      font-size: 14px;
      letter-spacing: 0.18em;
      user-select: none;
      pointer-events: none;
      display: flex;
      gap: 1.5em;
      align-items: baseline;
    }
    .book-pager .hint {
      color: rgba(255, 255, 255, 0.4);
      font-size: 11px;
      letter-spacing: 0.12em;
    }

    /* 放大 lightbox */
    .book-zoom {
      position: fixed; inset: 0;
      z-index: 9500;
      background: rgba(0, 0, 0, 0.96);
      display: none;
      align-items: center;
      justify-content: center;
      cursor: zoom-out;
      opacity: 0;
      transition: opacity 0.25s ease;
    }
    .book-zoom.is-open { display: flex; opacity: 1; }
    .book-zoom-pair {
      display: flex;
      gap: 4px;
      max-width: 96vw;
      max-height: 96vh;
    }
    .book-zoom-pair img {
      max-width: 48vw;
      max-height: 96vh;
      object-fit: contain;
    }
  </style>

  <section class="desk-room">
    <button class="magazine-sticker" id="magazine-sticker" aria-label="打开杂志">
      <img src="/desk/magazine-sticker.webp" alt="桌上的一本杂志" />
    </button>
    <div class="sticker-hint">点击杂志,翻开看看</div>
  </section>

  <!-- 翻书 overlay -->
  <div class="book-overlay" id="book-overlay" aria-hidden="true">
    <button class="book-close" id="book-close" aria-label="关闭">×</button>

    <button class="book-flank book-flank-left" id="flank-prev" aria-label="上一页">
      <span class="book-flank-arrow">‹</span>
    </button>
    <button class="book-flank book-flank-right" id="flank-next" aria-label="下一页">
      <span class="book-flank-arrow">›</span>
    </button>

    <div class="book-stage" id="book-stage">
      <div class="book-viewport" id="book-viewport">
        <div class="bf-page" id="bf-left"><img alt="" /></div>
        <div class="bf-page" id="bf-right"><img alt="" /></div>
      </div>
    </div>

    <div class="book-pager" id="book-pager">
      <span id="pager-num">1 / 1</span>
      <span class="hint">← / →  单击放大  ESC 关闭</span>
    </div>
  </div>

  <div class="book-zoom" id="book-zoom" aria-hidden="true">
    <div class="book-zoom-pair" id="book-zoom-pair"></div>
  </div>

  <script is:inline>
    // 39 单页 = blank + cover + cover-inside + 扉页 + 17×2 内容 + 2 结尾
    // 切成 spread 对(每对左右两页)
    const pageImages = ['/desk/page--blank.webp'];
    pageImages.push('/desk/page-00-cover.webp');
    pageImages.push('/desk/page-01-cover-inside.webp');
    pageImages.push('/desk/page-02-feiye.webp');
    for (let i = 3; i <= 38; i++) {
      pageImages.push(`/desk/page-${String(i).padStart(2, '0')}.webp`);
    }
    // 配对成 spread
    const spreads = [];
    for (let i = 0; i < pageImages.length; i += 2) {
      spreads.push([pageImages[i] || null, pageImages[i+1] || null]);
    }
    // spreads[0] = [blank, cover]  (打开看到右侧封面)
    // spreads[1] = [cover-inside, feiye]
    // spreads[2..] 内容

    const sticker = document.getElementById('magazine-sticker');
    const overlay = document.getElementById('book-overlay');
    const closeBtn = document.getElementById('book-close');
    const flankPrev = document.getElementById('flank-prev');
    const flankNext = document.getElementById('flank-next');
    const viewport = document.getElementById('book-viewport');
    const leftSlot = document.getElementById('bf-left').querySelector('img');
    const rightSlot = document.getElementById('bf-right').querySelector('img');
    const pagerNum = document.getElementById('pager-num');
    const zoom = document.getElementById('book-zoom');
    const zoomPair = document.getElementById('book-zoom-pair');

    // 移出 site-main stacking context
    document.body.appendChild(overlay);
    document.body.appendChild(zoom);

    let curSpread = 0;
    let isOpen = false;
    let isFlipping = false;

    // 预加载所有图
    let preloadDone = null;
    function preloadAll() {
      if (preloadDone) return preloadDone;
      preloadDone = Promise.all(pageImages.map((src) => new Promise((res) => {
        const img = new Image();
        img.onload = () => res();
        img.onerror = () => res();
        img.src = src;
      })));
      return preloadDone;
    }

    // 计算 book 尺寸 — 16:9 双页
    function computeBookSize() {
      const vw = window.innerWidth;
      const vh = window.innerHeight;
      const maxW = vw * 0.88;
      const maxH = vh * 0.88;
      const ratio = 2560 / 1440;  // 双页 16:9
      const bookW = Math.min(maxW, maxH * ratio);
      const bookH = bookW / ratio;
      viewport.style.setProperty('--book-width', `${bookW}px`);
      viewport.style.setProperty('--book-height', `${bookH}px`);
    }

    function renderSpread() {
      const sp = spreads[curSpread];
      leftSlot.src  = sp[0] || '';
      rightSlot.src = sp[1] || '';
      pagerNum.textContent = `${curSpread + 1} / ${spreads.length}`;
      flankPrev.disabled = (curSpread <= 0);
      flankNext.disabled = (curSpread >= spreads.length - 1);
    }

    function makePaper(direction, frontSrc, backSrc) {
      const paper = document.createElement('div');
      paper.className = `flip-paper ${direction}`;
      paper.innerHTML = `
        <div class="face front"><img src="${frontSrc || ''}" alt=""></div>
        <div class="face back"><img src="${backSrc || ''}" alt=""></div>
      `;
      return paper;
    }

    // 翻页动画时长(必须跟 CSS keyframes 一致)
    const FLIP_MS = 850;

    function finishFlip(paper, safety) {
      if (safety) clearTimeout(safety);
      if (paper && paper.parentNode) paper.remove();
      isFlipping = false;
    }

    function runFlip(direction, frontSrc, backSrc) {
      const paper = makePaper(direction, frontSrc, backSrc);
      viewport.appendChild(paper);
      // 强制 reflow,确保 animation 一定从 0 开始(防浏览器合并 reflow 导致动画不触发)
      void paper.offsetWidth;
      // 兜底:即便 animationend 因任何原因没触发,FLIP_MS + 200ms 后强制收尾
      const safety = setTimeout(() => finishFlip(paper, null), FLIP_MS + 200);
      paper.addEventListener('animationend', () => finishFlip(paper, safety), { once: true });
    }

    function flipNext() {
      if (isFlipping || curSpread >= spreads.length - 1) return;
      isFlipping = true;
      const oldRight = spreads[curSpread][1];
      const newLeft  = spreads[curSpread + 1][0];
      curSpread++;
      renderSpread();             // 立刻换容器内容,纸盖住看不到
      runFlip('forward', oldRight, newLeft);
    }

    function flipPrev() {
      if (isFlipping || curSpread <= 0) return;
      isFlipping = true;
      const oldLeft  = spreads[curSpread][0];
      const newRight = spreads[curSpread - 1][1];
      curSpread--;
      renderSpread();
      runFlip('backward', oldLeft, newRight);
    }

    // 单击书 = 放大 lightbox
    function openZoom() {
      if (isFlipping) return;
      zoomPair.innerHTML = '';
      const sp = spreads[curSpread];
      const showLeft = sp[0] && sp[0] !== '/desk/page--blank.webp';
      if (showLeft) {
        const il = document.createElement('img');
        il.src = sp[0];
        zoomPair.appendChild(il);
      }
      if (sp[1]) {
        const ir = document.createElement('img');
        ir.src = sp[1];
        zoomPair.appendChild(ir);
      }
      zoom.classList.add('is-open');
      zoom.setAttribute('aria-hidden', 'false');
    }
    function closeZoom() {
      zoom.classList.remove('is-open');
      zoom.setAttribute('aria-hidden', 'true');
    }

    // 翻书 open/close
    function openBook() {
      if (isOpen) return;
      isOpen = true;
      overlay.setAttribute('aria-hidden', 'false');
      overlay.classList.add('is-open');
      computeBookSize();
      preloadAll().then(() => {
        curSpread = 0;
        renderSpread();
      });
    }
    function closeBook() {
      if (!isOpen) return;
      isOpen = false;
      overlay.classList.remove('is-open');
      overlay.setAttribute('aria-hidden', 'true');
      closeZoom();
    }

    // 事件绑定
    sticker.addEventListener('click', openBook);
    closeBtn.addEventListener('click', closeBook);
    flankPrev.addEventListener('click', flipPrev);
    flankNext.addEventListener('click', flipNext);

    // 单击书 viewport → 放大;但不要拦截 flank 等按钮(它们 z-index 高)
    viewport.addEventListener('click', openZoom);

    overlay.addEventListener('click', (e) => {
      // 点击 overlay 蒙层(不是 viewport 或按钮)关闭
      if (e.target === overlay) closeBook();
    });

    zoom.addEventListener('click', closeZoom);

    document.addEventListener('keydown', (e) => {
      if (!isOpen) return;
      if (e.key === 'Escape') {
        if (zoom.classList.contains('is-open')) closeZoom();
        else closeBook();
      }
      else if (e.key === 'ArrowLeft')  flipPrev();
      else if (e.key === 'ArrowRight') flipNext();
    });

    window.addEventListener('resize', () => {
      if (isOpen) computeBookSize();
    });

    // 截图调试:?open=1[&spread=N]
    const qp = new URLSearchParams(location.search);
    if (qp.get('open') === '1') {
      setTimeout(() => {
        openBook();
        const s = parseInt(qp.get('spread') || '0', 10);
        if (s > 0) {
          setTimeout(() => {
            curSpread = Math.min(spreads.length - 1, Math.max(0, s));
            renderSpread();
          }, 500);
        }
      }, 100);
    }
  </script>
</Layout>
