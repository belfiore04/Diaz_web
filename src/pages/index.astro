---
import Layout from '../layouts/Layout.astro';
---

<Layout title="李多迪 — Diaz Lee">
  <section class="min-h-screen flex items-center justify-center px-16 bg-ink">
    <div class="text-center max-w-3xl">
      <p class="font-serif italic text-muted text-sm tracking-[0.3em] uppercase mb-8">Diaz Lee · 李多迪</p>
      <h1 class="font-cn text-paper text-7xl leading-tight mb-12">
        作品集主页
      </h1>
      <p class="font-cn text-muted text-lg leading-relaxed">
        这是主页占位——下一步从左侧导航进入任意项目页。
      </p>
      <div class="mt-16 flex justify-center gap-8 text-paper/60 text-xs font-serif italic tracking-widest uppercase">
        <a href="/projects/similar-case-search" class="hover:text-crimson">类案检索</a>
        <a href="/projects/meishuguan" class="hover:text-crimson">美书馆</a>
        <a href="/projects/forget-me-not" class="hover:text-crimson">Forget Me Not</a>
        <a href="/projects/lemon-tea-ip" class="hover:text-crimson">柠檬茶 IP</a>
      </div>
    </div>
  </section>
</Layout>
