---
import Layout from '../layouts/Layout.astro';

// 设计稿 (Figma 主页不滚动内容页 132:264): 2560 wide × 1440 tall, 一屏不滚动
// 注意 frame 是 2560 整 viewport 宽 (不是 1968 main 区域), 所以坐标基准用 2560
// 中文名 Assistant Bold, 其余 Kameron Bold
const items = [
  { x: 378,  y: 296,  w: 1804, fs: 128, color: '#fff', font: 'zh', align: 'right',  lh: 1,   text: '李        多  迪' },
  { x: 1705, y: 461,  w: 477,  fs: 96,  color: '#fff', font: 'bd', align: 'right',  lh: 1,   text: 'Diaz    Lee' },
  { x: 1720, y: 697,  w: 462,  fs: 32,  color: '#fff', font: 'bd', align: 'right',  lh: 1.2, text: '产品\nby AI · for humans · with care' },
  { x: 2118, y: 872,  w: 64,   fs: 32,  color: '#fff', font: 'bd', align: 'right',  lh: 1.2, text: '应用\n\n工具\n\n文字\n\n影像\n\n音乐\n\n艺术' },
  { x: 795,  y: 1322, w: 969,  fs: 32,  color: '#fff', font: 'bd', align: 'center', lh: 1.2, text: 'Email : diaz120404@163.com      ·      Tel : (+86) 159 0403 5157\nGitHub : github.com/belfiore04     ·     Wechat : DDDDDiaz' },
];

const fontMap: Record<string, string> = {
  zh: '"Assistant", "Noto Serif SC", "Songti SC", serif',
  bd: '"Kameron", "Noto Serif SC", "Songti SC", serif',
};

// 横向 cqw 基准 = 2560 (container 跨整 viewport), 纵向 vh 基准 = 1440
const cqw = (px: number) => `${(px / 2560 * 100).toFixed(3)}cqw`;
const vh  = (px: number) => `${(px / 1440 * 100).toFixed(3)}vh`;
---

<Layout
  title="李多迪 — Diaz Lee"
  bgImage="/MAIN.png"
  navColor="#fff"
  logoColor="#FF0000"
  highlightColor="#FF0000"
>
  <style>
    /* 主页跨整 viewport 布局, 跳出 site-main 限制 */
    .main-stage {
      position: fixed;
      inset: 0;
      width: 100vw;
      height: 100vh;
      container-type: inline-size;
      pointer-events: none;
      z-index: 1;
    }
    .main-stage > * {
      position: absolute;
      white-space: pre-wrap;
      pointer-events: auto;
    }
  </style>

  <section class="main-stage">
    {items.map((it) => {
      const style = [
        `left: ${cqw(it.x)}`,
        `top: ${vh(it.y)}`,
        `width: ${cqw(it.w)}`,
        `font-family: ${fontMap[it.font]}`,
        `font-weight: 700`,
        `font-size: ${cqw(it.fs)}`,
        `color: ${it.color}`,
        `text-align: ${it.align}`,
        `line-height: ${it.lh}`,
      ].join('; ');
      return <div style={style}>{it.text}</div>;
    })}
  </section>
</Layout>
