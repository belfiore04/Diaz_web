const fontMap: Record<string, string> = {
  zh: '"Assistant", "Noto Serif SC", "Songti SC", serif',
  en: '"Bebas Neue", sans-serif',
  mt: '"Kameron", "Noto Serif SC", serif',
  bd: '"Kameron", "Noto Serif SC", "Songti SC", serif',
};

const cqw = (px: number) => `${(px / 1968 * 100).toFixed(3)}cqw`;
const vh  = (px: number) => `${(px / 1440 * 100).toFixed(3)}vh`;
---

<Layout
  title="柠檬茶 IP 设计 — Diaz Lee"
  currentProject="lemon-tea-ip"
  bgImage="/lt-bg.png"
  highlightColor="#0049E5"
  bgOverlay={0.25}
>
  <style>
    .lt-first {
      position: relative;
      width: 100%;
      height: 100vh;
      container-type: inline-size;
    }
    .lt-first > * { position: absolute; white-space: pre-wrap; }

    .lt-stage {
      position: relative;
      width: 100%;
      aspect-ratio: 1968 / 20090;
      container-type: inline-size;
    }
    .lt-stage > * { position: absolute; white-space: pre-wrap; }
    .lt-stage img {
      object-fit: cover;
      display: block;
      border-radius: 3.049cqw; /* Figma 60px / 1968 设计宽 */
      cursor: zoom-in;
    }
    .lt-stage img.flat { border-radius: 0; }
    .lt-spacer { height: 50vh; }

    /* 滚动到视口时,元素从下淡入 */
    .lt-stage > * {
      opacity: 0;
      transform: translateY(14px);
      transition: opacity 0.9s ease-out, transform 0.9s ease-out;
      will-change: opacity, transform;
    }
    .lt-stage > .is-visible {
      opacity: 1;
      transform: translateY(0);
    }
    @media (prefers-reduced-motion: reduce) {
      .lt-stage > * { opacity: 1; transform: none; transition: none; }
    }
  </style>

  <!-- 首屏 -->
  <section class="lt-first">
    {firstScreenItems.map((it) => {
      const style = [
        `left: ${cqw(it.x)}`,
        `top: ${vh(it.y)}`,
        `width: ${cqw(it.w)}`,
        `font-family: ${fontMap[it.font]}`,
        `font-weight: 700`,
        `font-size: ${cqw(it.fs)}`,
        `color: ${it.color}`,
        `text-align: ${it.align}`,
        `line-height: ${it.lh}`,
      ].join('; ');
      return <div style={style}>{it.text}</div>;
    })}
  </section>

  <!-- 后续 stage -->
  <section class="lt-stage">
    {stageItems.map((it) => {
      if (it.type === 'img') {
        const yInStage = it.y - STAGE_OFFSET;
        return (
          <img
            src={it.src}
            alt=""
            class={it.flat ? 'flat' : ''}
            style={`left: ${cqw(it.x)}; top: ${cqw(yInStage)}; width: ${cqw(it.w)}; height: ${cqw(it.h!)};`}
          />
        );
      }
      const yInStage = (it.y as number) - STAGE_OFFSET;
      const style = [
        `left: ${cqw(it.x)}`,
        `top: ${cqw(yInStage)}`,
        `width: ${cqw(it.w!)}`,
        `font-family: ${fontMap[it.font!]}`,
        `font-weight: 700`,
        `font-size: ${cqw(it.fs!)}`,
        `color: ${it.color}`,
        `text-align: ${it.align}`,
        `line-height: ${it.lh}`,
      ].join('; ');
      return <div style={style}>{it.text}</div>;
    })}
  </section>

  <!-- 让结语能滚到屏幕中间 -->
  <div class="lt-spacer"></div>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const targets = document.querySelectorAll('.lt-stage > *');
      if (!('IntersectionObserver' in window)) {
        targets.forEach((el) => el.classList.add('is-visible'));
        return;
      }
      const io = new IntersectionObserver((entries, obs) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            obs.unobserve(e.target);
          }
        }
      }, { rootMargin: '0px 0px -8% 0px' });
      targets.forEach((el) => io.observe(el));
    });
  </script>
</Layout>
