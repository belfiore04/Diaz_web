---
import Layout from '../../layouts/Layout.astro';

// 设计稿 (Figma FMN滚动内容页 → 内容 frame 99:491): 1968 wide × 12790 tall
// 首屏 = y 0~1440, 后续 stage = y 1440~12790

// ===== 首屏 =====
const firstScreenItems = [
  { x: 453,  y: 776,  w: 1212, fs: 48, color: '#CE0000', font: 'zh', align: 'left',  lh: 1,   text: '勿                      忘         我' },
  { x: 1002, y: 900,  w: 663,  fs: 48, color: '#000',    font: 'en', align: 'right', lh: 1,   text: 'Forget              me                                             not' },
  { x: 1123, y: 1183, w: 542,  fs: 20, color: '#000',    font: 'bd', align: 'right', lh: 1.2, text: '2025 · Group Project\nReact · FastAPI · MySQL · FalkorDB\nMemory-centric RAG · Knowledge Graph · Multi-Agent\nmemoryclawv1.coolqq.com' },
];

const STAGE_HEIGHT = 11119; // 12790 - 1440
const STAGE_OFFSET = 1440;

// ===== 后续 stage =====
const stageItems = [
  // 1. WHY
  { x: 278,  y: 1440, w: 276, fs: 32, color: '#000', font: 'bd', align: 'left',  lh: 1.2, text: '1.WHY' },
  { x: 278,  y: 1508, w: 750, fs: 32, color: '#000', font: 'bd', align: 'left',  lh: 1.2, text: '大多数 AI 陪伴产品都有同一个症状\n\n每次打开,角色都像第一次见到你\n\n名字、上次聊到哪、你提过的偏好、\n\n你们之间发生过的事\n\n全部要重新介绍\n\n这不是陪伴\n\n是重新认识' },

  // 2. WHAT
  { x: 1389, y: 1840, w: 276, fs: 32, color: '#000', font: 'bd', align: 'right', lh: 1.2, text: '2.WHAT' },
  { x: 915,  y: 1908, w: 750, fs: 32, color: '#000', font: 'bd', align: 'right', lh: 1.2, text: '一个 AI 角色扮演聊天产品\n\n用户可以创建自己的 AI 角色\n\n给 TA 人设、价值观、口癖\n\n然后和 TA 持续对话\n\n区别于市面同类产品的核心\n\n记忆系统' },

  // 3. A NOTE ON RAG
  { x: 278,  y: 2491, w: 827,  fs: 32, color: '#000', font: 'bd', align: 'left',  lh: 1.2, text: '3.A NOTE ON RAG' },
  { x: 278,  y: 2559, w: 750,  fs: 32, color: '#000', font: 'bd', align: 'left',  lh: 1.2, text: '大多数产品的"记忆" = 把 chat history 喂回模型\n\n这种做法 context 一长\n\n角色就开始遗忘、错位、变成另一个人' },
  { x: 616,  y: 2900, w: 1073, fs: 32, color: '#000', font: 'bd', align: 'left',  lh: 1.2, text: '我把记忆抽象成三层\n\nSOUL — 角色自己的人设、价值观、口癖\n\nUSER — AI 视角下"它了解到的用户"画像\n\n后台 agent 增量更新\n\nMEMORY — 双方共同经历过的事实,Markdown 结构化存储' },
  { x: 704,  y: 3393, w: 1073, fs: 32, color: '#000', font: 'bd', align: 'right', lh: 1.2, text: '每次对话只 retrieve 当前需要的切片\n\n而不是 dump 全部历史' },
  { x: 283,  y: 3655, w: 1073, fs: 32, color: '#000', font: 'bd', align: 'left',  lh: 1.2, text: 'MEMORY 只存客观事实(发生了什么)\n\n主观感受、视角差异由 SOUL 在 runtime 当滤镜叠加上去\n\n这层分离让多角色场景下"同一件事不同角色记得不同"成为可能\n\n但底层事实是统一的' },

  // 功能截图 1: 聊天 (图在左)
  { type: 'img', src: '/fmn-chat.png', x: 234, y: 4106, w: 800, h: 1007 },
  { x: 1064, y: 4142, w: 750, fs: 32, color: '#000', font: 'bd', align: 'left', lh: 1.2, text: '单人聊天窗口' },
  { x: 1064, y: 4548, w: 750, fs: 32, color: '#000', font: 'bd', align: 'left', lh: 1.2, text: 'AI角色可以由你决定\n\n可以是你最近看过的意犹未尽的电影角色\n\n可以是你从小喜欢到大的IP角色\n\n可以是你自己创造出的角色\n\n也可以是我们为你准备好的角色\n\n他有记忆、有人格、有个性、有故事\n\n你说的话他都能接住' },

  // 功能截图 2: 角色卡 (图在右)
  { type: 'img', src: '/fmn-character.png', x: 1014, y: 5213, w: 800, h: 1076 },
  { x: 234, y: 5244, w: 750, fs: 32, color: '#000', font: 'bd', align: 'right', lh: 1.2, text: '角色卡片' },
  { x: 234, y: 5727, w: 750, fs: 32, color: '#000', font: 'bd', align: 'right', lh: 1.2, text: '每个他都有一张卡\n\n写着他是谁、他从哪里来\n\n他的喜恶、他的语言习惯\n\n他的口头禅\n\n他记得的那些过去\n\n写完\n\n他就站在你面前了' },

  // 功能截图 3: 记忆 (图在左)
  { type: 'img', src: '/fmn-memory.png', x: 204, y: 6389, w: 800, h: 1076 },
  { x: 1034, y: 6431, w: 750, fs: 32, color: '#000', font: 'bd', align: 'left', lh: 1.2, text: '角色记忆' },
  { x: 1034, y: 6903, w: 750, fs: 32, color: '#000', font: 'bd', align: 'left', lh: 1.2, text: '你上周提到的那件烦心事\n\n今天打开 他会先问一句\n\n你说过的话\n\n你们之间发生过的事\n\n他都记得\n\n你不是在反复介绍自己\n\n你是在被记得' },

  // 功能截图 4: 群组 (图在右)
  { type: 'img', src: '/fmn-group.png', x: 1014, y: 7565, w: 800, h: 1076 },
  { x: 234, y: 7586, w: 750, fs: 32, color: '#000', font: 'bd', align: 'right', lh: 1.2, text: '群组聊天窗口' },
  { x: 234, y: 8159, w: 750, fs: 32, color: '#000', font: 'bd', align: 'right', lh: 1.2, text: '谁在场\n\n你决定\n\n他们之前互不相识\n\n都因为你 来到这\n\n这是你的客厅\n\n他们一起在这里生活' },

  // 4. GROUP CHAT
  { x: 253, y: 8854, w: 372,  fs: 32, color: '#000', font: 'bd', align: 'left', lh: 1.2, text: '4.GROUP CHAT' },
  { x: 253, y: 8919, w: 1391, fs: 32, color: '#000', font: 'bd', align: 'left', lh: 1.2, text: '让模型一次性生成多人对话,不够稳健\n\n谁说话、说什么、什么时候打断,都容易乱\n\n拆成两阶段\n\n阶段 1(剧本指导) —— 规划这段对话有几个 Beat,每个 Beat 谁对谁说、主题是什么\n\n阶段 2(剧本生成) —— 根据规划填台词\n\nBeat 是编剧术语,不是 Turn,也不是 Floor\n\nFloor 是会话分析里"发言空间"的概念,状态性、即时涌现\n\n适合描述"实际发生了什么",不适合作为"事先编排的规划单元"\n\nBeat 自带"预设意图单元"的含义,和"剧本"的隐喻一致\n\n命名上的精细度,反映的是对场景理解的深度。' },

  // 5. MEMORY
  { x: 1272, y: 9734, w: 372,  fs: 32, color: '#000', font: 'bd', align: 'right', lh: 1.2, text: '5.MEMORY' },
  { x: 253,  y: 9799, w: 1391, fs: 32, color: '#000', font: 'bd', align: 'right', lh: 1.2, text: 'MEMORY 只存客观事实\n\n角色 A 觉得用户温柔\n\n角色 B 觉得用户神经质\n\n这两条都不写进 MEMORY\n\n写进 MEMORY 的是\n\n"用户连续三周每天都在晚上 11 点之后聊天"\n\n主观感受是各角色 SOUL 在 runtime 当滤镜叠加上去的\n\n这层分离让记忆层保持"客观共同事实"的调性\n\n不会因角色多了而混乱' },

  // 6. A NOTE ON AI CHAT
  { x: 253, y: 10555, w: 372,  fs: 32, color: '#000', font: 'bd', align: 'left', lh: 1.2, text: '6.A NOTE ON AI CHAT' },
  { x: 253, y: 10620, w: 1391, fs: 32, color: '#000', font: 'bd', align: 'left', lh: 1.2, text: 'AI 陪伴的护城河\n\n不是模型\n\n是关系的连续性\n\n关系的载体是记忆\n\n记忆不是 log\n\n是被结构化的事实\n\n角色不该每次都重新认识你\n\n这是一切的起点' },

  // 结语
  { x: 0, y: 11469, w: 1968, fs: 32, color: '#000', font: 'bd', align: 'center', lh: 1.6, text: '勿忘我\n\n是一种很小的花\n\n蓝紫色 不起眼\n\n它的名字\n\n就是它对世界唯一的请求\n\n我希望每一次\n\n你和他之间发生过的事\n\n都能像这朵花一样\n\n被记得' },
];

const fontMap: Record<string, string> = {
  zh: '"Assistant", "Noto Serif SC", "Songti SC", serif',
  en: '"Bebas Neue", sans-serif',
  bd: '"Kameron", "Noto Serif SC", "Songti SC", serif',
};

const cqw = (px: number) => `${(px / 1968 * 100).toFixed(3)}cqw`;
const vh  = (px: number) => `${(px / 1440 * 100).toFixed(3)}vh`;
---

<Layout
  title="Forget Me Not — Diaz Lee"
  currentProject="forget-me-not"
  bgImage="/FMN.png"
  highlightColor="#CE0000"
  navColor="#000"
>
  <style>
    .fmn-first {
      position: relative;
      width: 100%;
      height: 100vh;
      container-type: inline-size;
    }
    .fmn-first > * { position: absolute; white-space: pre-wrap; }

    .fmn-stage {
      position: relative;
      width: 100%;
      aspect-ratio: 1968 / 11119;
      container-type: inline-size;
    }
    .fmn-stage > * { position: absolute; white-space: pre-wrap; }
    .fmn-stage img {
      object-fit: cover;
      display: block;
      border-radius: 3.049cqw;
      cursor: zoom-in;
    }

    .fmn-stage > * {
      opacity: 0;
      transform: translateY(14px);
      transition: opacity 0.9s ease-out, transform 0.9s ease-out;
      will-change: opacity, transform;
    }
    .fmn-stage > .is-visible {
      opacity: 1;
      transform: translateY(0);
    }
    @media (prefers-reduced-motion: reduce) {
      .fmn-stage > * { opacity: 1; transform: none; transition: none; }
    }
  </style>

  <!-- 首屏 -->
  <section class="fmn-first">
    {firstScreenItems.map((it) => {
      const style = [
        `left: ${cqw(it.x)}`,
        `top: ${vh(it.y)}`,
        `width: ${cqw(it.w)}`,
        `font-family: ${fontMap[it.font]}`,
        `font-weight: 700`,
        `font-size: ${cqw(it.fs)}`,
        `color: ${it.color}`,
        `text-align: ${it.align}`,
        `line-height: ${it.lh}`,
      ].join('; ');
      return <div style={style}>{it.text}</div>;
    })}
  </section>

  <!-- 后续 stage -->
  <section class="fmn-stage">
    {stageItems.map((it) => {
      if (it.type === 'img') {
        const yInStage = it.y - STAGE_OFFSET;
        return (
          <img
            src={it.src}
            alt=""
            style={`left: ${cqw(it.x)}; top: ${cqw(yInStage)}; width: ${cqw(it.w)}; height: ${cqw(it.h!)};`}
          />
        );
      }
      const yInStage = (it.y as number) - STAGE_OFFSET;
      const style = [
        `left: ${cqw(it.x)}`,
        `top: ${cqw(yInStage)}`,
        `width: ${cqw(it.w!)}`,
        `font-family: ${fontMap[it.font!]}`,
        `font-weight: 700`,
        `font-size: ${cqw(it.fs!)}`,
        `color: ${it.color}`,
        `text-align: ${it.align}`,
        `line-height: ${it.lh}`,
      ].join('; ');
      return <div style={style}>{it.text}</div>;
    })}
  </section>

  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const targets = document.querySelectorAll('.fmn-stage > *');
      if (!('IntersectionObserver' in window)) {
        targets.forEach((el) => el.classList.add('is-visible'));
        return;
      }
      const io = new IntersectionObserver((entries, obs) => {
        for (const e of entries) {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            obs.unobserve(e.target);
          }
        }
      }, { rootMargin: '0px 0px -8% 0px' });
      targets.forEach((el) => io.observe(el));
    });
  </script>
</Layout>
